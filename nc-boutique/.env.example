# Variables d'environnement — nc-boutique (Boutique client publique)
# Copier ce fichier en .env.local pour le développement local
# Ces valeurs DOIVENT être configurées dans Vercel Dashboard (Settings > Environment Variables)
# Référence complète : AGENTS.md > Variables d'environnement

# ── Supabase — mêmes valeurs que vercel-quick ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://alyxejkdtkdmluvgfnqk.supabase.co
# Clé publique (anon) — format eyJ... — visible côté client (safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clé privée (service role) — format eyJ... — SERVEUR UNIQUEMENT, jamais côté client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Sécurité Boutique ────────────────────────────────────────────────────────
# Token secret pour les appels inter-services (boutique ↔ dashboard)
# Générer avec : openssl rand -base64 32
BOUTIQUE_SECRET=...

# ── ZR Express (suivi colis public) ─────────────────────────────────────────
# Clé API ZR Express (voir docs/integrations/ZR_EXPRESS.md)
ZR_API_KEY=...

# ── Pixels Facebook (optionnel — Phase 2) ───────────────────────────────────
# IDs des pixels Facebook par monde (T14 — TODO)
# NEXT_PUBLIC_FB_PIXEL_COIFFURE=...
# NEXT_PUBLIC_FB_PIXEL_ONGLERIE=...

# ── Variables NON requises en nc-boutique (restent dans vercel-quick) ────────
# SHOPIFY_ACCESS_TOKEN
# SHOPIFY_WEBHOOK_SECRET
# DASHBOARD_SECRET
# VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY
# ZR_TENANT_ID
